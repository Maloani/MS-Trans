<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fond Bleu -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#007FFF" />
        </shape>
    </item>

    <!-- Bande diagonale Rouge -->
    <item>
        <rotate
            android:fromDegrees="-45"
            android:pivotX="50%"
            android:pivotY="50%">
            <shape android:shape="rectangle">
                <size
                    android:height="40dp"
                    android:width="999dp" />
                <solid android:color="#CE1021" />
            </shape>
        </rotate>
    </item>

    <!-- Bordure Jaune autour de la bande Rouge -->
    <item>
        <rotate
            android:fromDegrees="-45"
            android:pivotX="50%"
            android:pivotY="50%">
            <shape android:shape="rectangle">
                <size
                    android:height="48dp"
                    android:width="999dp" />
                <solid android:color="#F7D618" />
            </shape>
        </rotate>
    </item>

</layer-list>
